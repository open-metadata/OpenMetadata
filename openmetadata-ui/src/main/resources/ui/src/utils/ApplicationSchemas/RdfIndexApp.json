{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RDF Knowledge Graph Indexing",
  "type": "object",
  "description": "Configuration for RDF knowledge graph indexing.",
  "properties": {
    "entities": {
      "title": "Entities",
      "description": "List of entities that you need to reindex. Leave empty to index all supported entities.",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "aiApplication",
          "aiGovernancePolicy",
          "apiCollection",
          "apiEndpoint",
          "apiService",
          "app",
          "appMarketPlaceDefinition",
          "bot",
          "chart",
          "classification",
          "container",
          "dashboard",
          "dashboardDataModel",
          "dashboardService",
          "dataContract",
          "dataInsightChart",
          "dataInsightCustomChart",
          "dataProduct",
          "database",
          "databaseSchema",
          "databaseService",
          "directory",
          "document",
          "domain",
          "driveService",
          "eventsubscription",
          "file",
          "glossary",
          "glossaryTerm",
          "ingestionPipeline",
          "kpi",
          "learningResource",
          "llmModel",
          "llmService",
          "messagingService",
          "metadataService",
          "metric",
          "mlmodel",
          "mlmodelService",
          "notificationTemplate",
          "persona",
          "pipeline",
          "pipelineService",
          "policy",
          "promptTemplate",
          "query",
          "report",
          "role",
          "searchIndex",
          "searchService",
          "securityService",
          "spreadsheet",
          "storageService",
          "storedProcedure",
          "table",
          "tag",
          "team",
          "testCase",
          "testConnectionDefinition",
          "testDefinition",
          "testSuite",
          "topic",
          "type",
          "user",
          "webAnalyticEvent",
          "workflow",
          "workflowDefinition",
          "worksheet"
        ]
      },
      "default": [],
      "uiFieldType": "treeSelect",
      "uniqueItems": true
    },
    "recreateIndex": {
      "title": "Recreate RDF Store",
      "description": "Clear the RDF store before indexing.",
      "type": "boolean",
      "default": false
    },
    "batchSize": {
      "title": "Batch Size",
      "description": "Maximum number of entities processed in a batch.",
      "type": "integer",
      "default": 100,
      "minimum": 1
    },
    "producerThreads": {
      "title": "Producer Threads",
      "description": "Number of producer threads to use for non-distributed RDF indexing.",
      "type": "integer",
      "default": 2,
      "minimum": 1,
      "maximum": 10
    },
    "consumerThreads": {
      "title": "Consumer Threads",
      "description": "Number of consumer threads to use for non-distributed RDF indexing.",
      "type": "integer",
      "default": 3,
      "minimum": 1,
      "maximum": 5
    },
    "queueSize": {
      "title": "Queue Size",
      "description": "Internal queue size for non-distributed RDF indexing.",
      "type": "integer",
      "default": 5000,
      "minimum": 1
    },
    "useDistributedIndexing": {
      "title": "Use Distributed Indexing",
      "description": "Enable distributed RDF indexing with partition coordination and recovery.",
      "type": "boolean",
      "default": true
    },
    "partitionSize": {
      "title": "Partition Size",
      "description": "Number of entities per partition for distributed RDF indexing.",
      "type": "integer",
      "default": 10000,
      "minimum": 1000,
      "maximum": 50000
    }
  },
  "additionalProperties": false
}
