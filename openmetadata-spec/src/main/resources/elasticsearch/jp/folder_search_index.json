{
  "settings": {
    "index": { "max_ngram_diff": 7 },
    "analysis": {
      "normalizer": {
        "lowercase_normalizer": { "type": "custom", "char_filter": [], "filter": ["lowercase"] }
      },
      "tokenizer": {
        "om_ngram_tokenizer": { "type": "ngram", "min_gram": 3, "max_gram": 10, "token_chars": ["letter", "digit"] }
      },
      "analyzer": {
        "om_analyzer": { "tokenizer": "letter", "filter": ["lowercase", "om_stemmer"] },
        "om_ngram": { "type": "custom", "tokenizer": "om_ngram_tokenizer", "filter": ["lowercase"] }
      },
      "filter": {
        "om_stemmer": { "type": "stemmer", "name": "english" }
      }
    }
  },
  "mappings": {
    "properties": {
      "id": { "type": "text" },
      "name": {
        "type": "keyword",
        "normalizer": "lowercase_normalizer",
        "fields": {
          "keyword": { "type": "keyword", "ignore_above": 256 }
        }
      },
      "fullyQualifiedName": { "type": "keyword", "normalizer": "lowercase_normalizer" },
      "displayName": {
        "type": "text",
        "analyzer": "om_analyzer",
        "fields": {
          "keyword": { "type": "keyword", "normalizer": "lowercase_normalizer", "ignore_above": 256 },
          "ngram": { "type": "text", "analyzer": "om_ngram" }
        }
      },
      "entityType": { "type": "keyword" },
      "description": { "type": "text" },
      "deleted": { "type": "boolean" },
      "childrenCount": { "type": "integer" },
      "parent": {
        "properties": {
          "id": { "type": "keyword" },
          "type": { "type": "keyword" },
          "name": { "type": "keyword", "normalizer": "lowercase_normalizer" },
          "displayName": { "type": "keyword" }
        }
      },
      "owners": {
        "type": "nested",
        "properties": {
          "id": { "type": "keyword" },
          "type": { "type": "keyword" },
          "name": { "type": "keyword", "normalizer": "lowercase_normalizer" },
          "displayName": { "type": "keyword" }
        }
      },
      "tags": {
        "properties": {
          "tagFQN": { "type": "keyword", "normalizer": "lowercase_normalizer" },
          "labelType": { "type": "keyword" },
          "source": { "type": "keyword" }
        }
      },
      "followers": { "type": "keyword" },
      "version": { "type": "float" },
      "updatedAt": { "type": "date", "format": "epoch_second" },
      "updatedBy": { "type": "text" }
    }
  }
}
