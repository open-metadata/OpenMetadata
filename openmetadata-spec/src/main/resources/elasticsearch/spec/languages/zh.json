{
  "analyzers" : {
    "om_analyzer" : "ik_max_word"
  },
  "settings" : {
    "analysis" : {
      "analyzer" : {
        "om_analyzer" : {
          "tokenizer" : "letter",
          "filter" : [ "lowercase", "om_stemmer" ]
        }
      },
      "filter" : {
        "om_stemmer" : {
          "name" : "english"
        },
        "word_delimiter_filter" : null
      },
      "tokenizer" : {
        "n_gram_tokenizer" : {
          "min_gram" : 2,
          "max_gram" : 3
        }
      }
    },
    "index" : {
      "max_ngram_diff" : 1
    }
  }
}
