{
  "entity" : "api_collection",
  "extends" : "entity_base",
  "javaEntity" : "org.openmetadata.schema.entity.data.APICollection",
  "settings" : {
    "byLanguage" : {
      "en" : { },
      "jp" : {
        "index" : {
          "max_ngram_diff" : 17
        },
        "analysis" : {
          "tokenizer" : {
            "n_gram_tokenizer" : {
              "min_gram" : 3,
              "max_gram" : 20
            }
          },
          "analyzer" : {
            "om_analyzer" : {
              "tokenizer" : "standard",
              "filter" : [ "lowercase", "word_delimiter_filter", "om_stemmer" ]
            },
            "om_analyzer_jp" : null
          },
          "filter" : {
            "om_stemmer" : {
              "name" : "kstem"
            },
            "word_delimiter_filter" : {
              "type" : "word_delimiter",
              "preserve_original" : true
            }
          }
        }
      },
      "ru" : { },
      "zh" : {
        "analysis" : {
          "tokenizer" : {
            "n_gram_tokenizer" : {
              "min_gram" : 1,
              "max_gram" : 2
            }
          }
        }
      }
    }
  },
  "fields" : {
