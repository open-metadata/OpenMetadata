{
  "entity" : "domain",
  "extends" : "entity_base",
  "settings" : {
    "byLanguage" : {
      "en" : { },
      "jp" : {
        "index" : {
          "max_ngram_diff" : 17
        },
        "analysis" : {
          "tokenizer" : {
            "n_gram_tokenizer" : {
              "min_gram" : 3,
              "max_gram" : 10
            }
          }
        }
      },
      "ru" : { },
      "zh" : {
        "index" : {
          "max_ngram_diff" : 17
        }
      }
    }
  },
  "fields" : {
    "domainType" : {
      "inline" : {
        "type" : "text",
        "fields" : {
          "keyword" : {
            "type" : "keyword",
            "normalizer" : "lowercase_normalizer",
            "ignore_above" : 256
          }
        }
      }
    },
    "name" : {
      "languages" : {
        "zh" : {
          "search_analyzer" : "ik_smart"
        }
      }
