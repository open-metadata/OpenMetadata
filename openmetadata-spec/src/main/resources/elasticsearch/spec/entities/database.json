          "search_analyzer" : "ik_smart"
        }
      }
    },
    "displayName" : {
      "type" : "text_search_full",
      "languages" : {
        "zh" : {
          "search_analyzer" : "ik_smart"
        }
      }
    },
    "description" : {
      "languages" : {
        "jp" : {
          "term_vector" : null
        },
        "zh" : {
          "search_analyzer" : "ik_smart",
          "term_vector" : null
        }
      }
    },
    "tier" : {
      "languages" : {
