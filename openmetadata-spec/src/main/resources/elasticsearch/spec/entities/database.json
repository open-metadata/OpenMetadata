{
  "entity" : "database",
  "extends" : "entity_base",
  "javaEntity" : "org.openmetadata.schema.entity.data.Database",
  "settings" : {
    "byLanguage" : {
      "en" : { },
      "jp" : {
        "index" : {
          "max_ngram_diff" : 17
        },
        "analysis" : {
          "analyzer" : {
            "om_analyzer" : {
              "tokenizer" : "letter",
              "filter" : [ "lowercase", "om_stemmer" ]
            }
          }
        }
      },
      "ru" : { },
      "zh" : {
        "index" : {
          "max_ngram_diff" : 17
        }
      }
    }
  },
  "fields" : {
    "name" : {
      "languages" : {
