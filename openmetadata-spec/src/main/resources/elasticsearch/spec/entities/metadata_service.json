{
  "entity" : "metadata_service",
  "extends" : "entity_base",
  "settings" : {
    "byLanguage" : {
      "en" : { },
      "jp" : {
        "analysis" : {
          "analyzer" : {
            "om_analyzer" : {
              "tokenizer" : "letter",
              "filter" : [ "lowercase", "om_stemmer" ]
            }
          }
        }
      },
      "ru" : { },
      "zh" : {
        "analysis" : {
          "tokenizer" : {
            "n_gram_tokenizer" : {
              "min_gram" : 1,
              "max_gram" : 2
            }
          }
        }
      }
    }
  },
  "fields" : {
    "name" : {
      "languages" : {
        "zh" : {
          "search_analyzer" : "ik_smart"
        }
      }
    },
    "displayName" : {
      "inline" : {
        "type" : "text",
        "analyzer" : "om_analyzer",
        "fields" : {
          "keyword" : {
            "type" : "keyword",
            "ignore_above" : 256
          },
          "ngram" : {
            "type" : "text",
            "analyzer" : "om_ngram"
          },
          "compound" : {
            "type" : "text",
            "analyzer" : "om_compound_analyzer"
          }
        }
      },
      "languages" : {
        "zh" : {
          "search_analyzer" : "ik_smart"
        }
      }
    },
    "description" : {
      "inline" : {
        "type" : "text",
        "analyzer" : "om_analyzer",
        "index_options" : "docs",
        "term_vector" : "with_positions_offsets"
      },
      "languages" : {
        "jp" : {
          "index_options" : null,
          "term_vector" : null
        },
        "zh" : {
          "search_analyzer" : "ik_smart",
          "index_options" : null,
          "term_vector" : null
        }
      },
      "type" : null
    },
    "domains" : {
      "overrides" : {
        "properties" : {
          "name" : {
            "fields" : {
              "keyword" : {
                "normalizer" : null
              }
            }
          }
        }
      },
      "languages" : {
        "jp" : null,
        "zh" : null
      }
    },
    "pipelines" : {
      "fragment" : "entityReference",
      "overrides" : {
        "properties" : {
          "name" : {
            "fields" : {
              "keyword" : {
                "normalizer" : null
              }
            }
          },
          "fullyQualifiedName" : {
            "type" : "text"
          },
          "displayName" : null
        }
      }
    },
    "tier" : {
      "languages" : {
        "jp" : {
          "properties" : {
            "tagFQN" : {
              "fields" : {
                "text" : {
                  "analyzer" : "om_analyzer"
                }
              },
              "normalizer" : null
            }
          }
        },
        "ru" : {
          "properties" : {
            "tagFQN" : {
              "normalizer" : null
            }
          }
        },
        "zh" : {
          "properties" : {
            "tagFQN" : {
              "fields" : {
                "text" : {
                  "analyzer" : "om_analyzer"
                }
              },
              "normalizer" : null
            }
          }
        }
      }
    },
    "tags" : {
      "languages" : {
        "jp" : {
          "properties" : {
            "tagFQN" : {
              "fields" : {
                "text" : {
                  "analyzer" : "om_analyzer"
                }
              }
            }
          }
        },
        "zh" : {
          "properties" : {
            "tagFQN" : {
              "fields" : {
                "text" : {
                  "analyzer" : "om_analyzer"
                }
              }
            }
          }
        }
      }
    },
    "owners" : {
      "overrides" : {
        "type" : "nested",
        "properties" : {
          "name" : {
            "normalizer" : "lowercase_normalizer",
            "fields" : {
              "keyword" : {
                "normalizer" : null
              }
            }
          },
          "fullyQualifiedName" : {
            "type" : "text"
          }
        }
      }
    },
    "provider" : {
      "type" : "text"
    },
    "votes" : {
      "inline" : {
        "dynamic" : false,
        "properties" : {
          "upVotes" : {
            "type" : "integer"
          },
          "downVotes" : {
            "type" : "integer"
          }
        }
      },
      "languages" : {
        "zh" : null
      }
    },
    "fqnParts" : null,
    "dataProducts" : null,
    "service" : null,
    "followers" : null,
    "certification" : null
