{
  "entity" : "column",
  "extends" : "entity_base",
  "settings" : {
    "byLanguage" : {
      "en" : {
        "index" : {
          "max_ngram_diff" : 7
        },
        "analysis" : {
          "tokenizer" : {
            "n_gram_tokenizer" : {
              "max_gram" : 10
            }
          }
        }
      },
      "jp" : {
        "analysis" : {
          "analyzer" : {
            "om_analyzer" : {
              "tokenizer" : "letter",
              "filter" : [ "lowercase", "om_stemmer" ]
            }
          }
        }
      },
      "ru" : {
        "index" : {
          "max_ngram_diff" : 7
        },
        "analysis" : {
          "tokenizer" : {
            "n_gram_tokenizer" : {
              "max_gram" : 10
            }
          }
        }
      },
      "zh" : { }
    }
  },
  "fields" : {
