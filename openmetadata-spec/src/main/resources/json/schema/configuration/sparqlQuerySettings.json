{
  "$id": "https://open-metadata.org/schema/configuration/sparqlQuerySettings.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SparqlQuerySettings",
  "description": "Administrator-managed SPARQL query templates available across the installation.",
  "type": "object",
  "javaType": "org.openmetadata.schema.configuration.SparqlQuerySettings",
  "properties": {
    "queryTemplates": {
      "description": "Installation query templates visible to SPARQL console users.",
      "type": "array",
      "maxItems": 50,
      "items": {
        "$ref": "../api/rdf/savedSparqlQuery.json"
      },
      "default": []
    }
  },
  "required": ["queryTemplates"],
  "additionalProperties": false
}
