{
  "$id": "https://open-metadata.org/schema/entity/services/connections/pipeline/tableauPipelineConnection.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TableauPipelineConnection",
  "description": "Tableau Pipeline Connection Config",
  "type": "object",
  "javaType": "org.openmetadata.schema.services.connections.pipeline.TableauPipelineConnection",
  "definitions": {
    "TableauPipelineType": {
      "description": "Service type.",
      "type": "string",
      "enum": ["TableauPipeline"],
      "default": "TableauPipeline"
    }
  },
  "properties": {
    "type": {
      "title": "Service Type",
      "description": "Service Type",
      "$ref": "#/definitions/TableauPipelineType",
      "default": "TableauPipeline"
    },
    "hostPort": {
      "expose": true,
      "title": "Host and Port",
      "description": "Tableau Server URL.",
      "type": "string",
      "format": "uri"
    },
    "authType": {
      "mask": true,
      "title": "Authentication type for Tableau",
      "description": "Types of methods used to authenticate to the tableau instance",
      "oneOf": [
        {
          "$ref": "../../../../security/credentials/basicAuth.json"
        },
        {
          "$ref": "../../../../security/credentials/accessTokenAuth.json"
        }
      ]
    },
    "siteName": {
      "title": "Site Name",
      "description": "Tableau Site Name.",
      "type": "string",
      "default": null
    },
    "apiVersion": {
      "title": "API Version",
      "description": "Tableau API version. If not provided, the version will be used from the tableau server.",
      "type": "string",
      "default": null
    },
    "verifySSL": {
      "$ref": "../../../../security/ssl/verifySSLConfig.json#/definitions/verifySSL",
      "default": "no-ssl"
    },
    "sslConfig": {
      "$ref": "../../../../security/ssl/verifySSLConfig.json#/definitions/sslConfig"
    },
    "pipelineFilterPattern": {
      "description": "Regex exclude or include pipelines that match the pattern.",
      "$ref": "../../../../type/filterPattern.json#/definitions/filterPattern",
      "title": "Default Pipeline Filter Pattern"
    },
    "numberOfStatus": {
      "description": "Number of recent flow runs to fetch per flow.",
      "type": "integer",
      "default": 10
    },
    "supportsMetadataExtraction": {
      "title": "Supports Metadata Extraction",
      "$ref": "../connectionBasicType.json#/definitions/supportsMetadataExtraction"
    },
    "supportsLineageExtraction": {
      "$ref": "../connectionBasicType.json#/definitions/supportsLineageExtraction"
    }
  },
  "additionalProperties": false,
  "required": ["hostPort", "authType"]
}
