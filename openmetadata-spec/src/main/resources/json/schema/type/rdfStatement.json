{
  "$id": "https://open-metadata.org/schema/type/rdfStatement.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RdfStatement",
  "description": "A typed, canonical RDF statement used by ontology version diffs.",
  "type": "object",
  "javaType": "org.openmetadata.schema.type.RdfStatement",
  "definitions": {
    "objectKind": {
      "javaType": "org.openmetadata.schema.type.RdfObjectKind",
      "type": "string",
      "enum": ["IRI", "LITERAL"]
    }
  },
  "properties": {
    "subjectIri": {
      "type": "string",
      "format": "uri"
    },
    "predicateIri": {
      "type": "string",
      "format": "uri"
    },
    "objectKind": {
      "$ref": "#/definitions/objectKind"
    },
    "objectIri": {
      "type": "string",
      "format": "uri"
    },
    "literalValue": {
      "type": "string"
    },
    "datatypeIri": {
      "type": "string",
      "format": "uri"
    },
    "language": {
      "type": "string"
    }
  },
  "required": ["subjectIri", "predicateIri", "objectKind"],
  "additionalProperties": false
}
