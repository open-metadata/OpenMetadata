{
  "$id": "https://open-metadata.org/schema/type/ontologyRelationship.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OntologyRelationship",
  "description": "A stable, directed semantic relationship between two glossary terms.",
  "type": "object",
  "javaType": "org.openmetadata.schema.type.OntologyRelationship",
  "properties": {
    "id": {
      "$ref": "basic.json#/definitions/uuid"
    },
    "fromTerm": {
      "$ref": "entityReference.json"
    },
    "toTerm": {
      "$ref": "entityReference.json"
    },
    "relationshipType": {
      "$ref": "entityReference.json"
    },
    "provenance": {
      "$ref": "termRelation.json#/definitions/provenance"
    },
    "status": {
      "$ref": "status.json"
    },
    "createdBy": {
      "description": "User who first authored or imported the relationship.",
      "type": "string"
    },
    "createdAt": {
      "$ref": "basic.json#/definitions/timestamp"
    }
  },
  "required": [
    "id",
    "fromTerm",
    "toTerm",
    "relationshipType",
    "provenance",
    "status",
    "createdBy",
    "createdAt"
  ],
  "additionalProperties": false
}
