    },
    "sessionId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "acquiredAt": {
      "$ref": "basic.json#/definitions/timestamp"
    },
    "renewedAt": {
      "$ref": "basic.json#/definitions/timestamp"
    },
    "expiresAt": {
      "$ref": "basic.json#/definitions/timestamp"
    }
  },
  "required": [
    "resourceType",
    "resourceId",
    "holder",
    "sessionId",
    "version",
    "acquiredAt",
    "renewedAt",
    "expiresAt"
