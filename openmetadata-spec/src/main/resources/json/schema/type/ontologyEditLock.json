{
  "$id": "https://open-metadata.org/schema/type/ontologyEditLock.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OntologyEditLock",
  "description": "A renewable lease guarding an ontology authoring resource.",
  "type": "object",
  "javaType": "org.openmetadata.schema.type.OntologyEditLock",
  "properties": {
