{
  "$id": "https://open-metadata.org/schema/api/data/ontologyRelationshipSuggestionRequest.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OntologyRelationshipSuggestionRequest",
  "description": "Request relationship proposals for existing concepts in one editable ontology.",
  "type": "object",
  "javaType": "org.openmetadata.schema.api.data.OntologyRelationshipSuggestionRequest",
  "properties": {
    "glossary": {
      "$ref": "../../type/basic.json#/definitions/fullyQualifiedEntityName"
    },
    "sourceTermIds": {
      "type": "array",
      "items": {
        "$ref": "../../type/basic.json#/definitions/uuid"
      },
      "minItems": 1,
      "maxItems": 25,
      "uniqueItems": true
    },
    "candidateTermIds": {
      "type": "array",
      "items": {
        "$ref": "../../type/basic.json#/definitions/uuid"
      },
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true
    },
    "relationshipTypeIds": {
      "type": "array",
      "items": {
        "$ref": "../../type/basic.json#/definitions/uuid"
      },
      "minItems": 1,
      "maxItems": 25,
      "uniqueItems": true
    },
    "instructions": {
      "type": "string",
      "maxLength": 4000
    },
    "maxSuggestions": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25,
      "default": 10
    }
  },
  "required": [
    "glossary",
    "sourceTermIds",
    "candidateTermIds",
    "relationshipTypeIds",
    "maxSuggestions"
  ],
  "additionalProperties": false
}
