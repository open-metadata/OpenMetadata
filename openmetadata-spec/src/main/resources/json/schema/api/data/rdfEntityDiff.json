{
  "$id": "https://open-metadata.org/schema/api/data/rdfEntityDiff.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RdfEntityDiff",
  "description": "Canonical RDF statement changes between two versions of one entity.",
  "type": "object",
  "javaType": "org.openmetadata.schema.api.data.RdfEntityDiff",
  "properties": {
    "entityId": {
      "$ref": "../../type/basic.json#/definitions/uuid"
    },
    "entityType": {
      "type": "string"
    },
    "fromVersion": {
      "$ref": "../../type/entityHistory.json#/definitions/entityVersion"
    },
    "toVersion": {
      "$ref": "../../type/entityHistory.json#/definitions/entityVersion"
    },
    "addedStatements": {
      "type": "array",
      "items": {
        "$ref": "../../type/rdfStatement.json"
      },
      "default": []
    },
    "removedStatements": {
      "type": "array",
      "items": {
        "$ref": "../../type/rdfStatement.json"
      },
      "default": []
    }
  },
  "required": [
    "entityId",
    "entityType",
    "fromVersion",
    "toVersion",
    "addedStatements",
    "removedStatements"
  ],
  "additionalProperties": false
}
