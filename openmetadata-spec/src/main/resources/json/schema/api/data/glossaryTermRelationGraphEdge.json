      "$ref": "../../type/basic.json#/definitions/uuid"
    },
    "to": {
      "description": "Identifier of the target glossary term.",
      "$ref": "../../type/basic.json#/definitions/uuid"
    },
    "relationType": {
      "description": "Configured type of the glossary relation.",
      "type": "string"
    },
    "relationshipType": {
      "description": "Resolved first-class relationship type.",
      "$ref": "../../type/entityReference.json"
    },
    "provenance": {
      "$ref": "../../type/termRelation.json#/definitions/provenance"
    },
    "status": {
      "$ref": "../../type/status.json"
    },
    "createdBy": {
      "type": "string"
    },
    "createdAt": {
      "$ref": "../../type/basic.json#/definitions/timestamp"
    }
  },
  "required": ["id", "from", "to", "relationType", "provenance", "status"],
  "additionalProperties": false
}
