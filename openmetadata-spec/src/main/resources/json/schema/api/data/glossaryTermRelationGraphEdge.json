{
  "$id": "https://open-metadata.org/schema/api/data/glossaryTermRelationGraphEdge.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GlossaryTermRelationGraphEdge",
  "description": "A directed, typed relation between two glossary terms.",
  "type": "object",
