{
  "$id": "https://open-metadata.org/schema/api/data/installOntologyPack.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InstallOntologyPack",
  "description": "Dry-run or install selected modules from a verified ontology pack.",
  "type": "object",
  "javaType": "org.openmetadata.schema.api.data.InstallOntologyPack",
  "properties": {
    "moduleIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "targetGlossaryName": {
      "$ref": "../../type/basic.json#/definitions/entityName"
    },
    "dryRun": {
      "type": "boolean",
      "default": true
    }
  },
  "required": ["moduleIds", "targetGlossaryName", "dryRun"],
  "additionalProperties": false
}
