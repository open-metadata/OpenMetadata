{
  "$id": "https://open-metadata.org/schema/api/data/ontologyMappingSuggestionRequest.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OntologyMappingSuggestionRequest",
  "description": "Request standards mappings for existing ontology concepts.",
  "type": "object",
  "javaType": "org.openmetadata.schema.api.data.OntologyMappingSuggestionRequest",
  "properties": {
    "glossary": {
      "$ref": "../../type/basic.json#/definitions/fullyQualifiedEntityName"
    },
    "sourceTermIds": {
      "type": "array",
      "items": {
        "$ref": "../../type/basic.json#/definitions/uuid"
      },
      "minItems": 1,
      "maxItems": 25,
      "uniqueItems": true
    },
    "standards": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true
    },
    "instructions": {
      "type": "string",
      "maxLength": 4000
    },
    "maxSuggestions": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25,
      "default": 10
    }
  },
  "required": ["glossary", "sourceTermIds", "standards", "maxSuggestions"],
  "additionalProperties": false
}
