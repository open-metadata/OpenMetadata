{
  "$id": "https://open-metadata.org/schema/api/data/ontologyDeleteResult.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OntologyDeleteResult",
  "description": "Result of a token-protected ontology resource deletion.",
  "type": "object",
