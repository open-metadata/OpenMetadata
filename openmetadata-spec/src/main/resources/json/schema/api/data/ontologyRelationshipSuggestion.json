{
  "$id": "https://open-metadata.org/schema/api/data/ontologyRelationshipSuggestion.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OntologyRelationshipSuggestion",
  "description": "A validated relationship proposal represented as a Draft-ready operation.",
  "type": "object",
  "javaType": "org.openmetadata.schema.api.data.OntologyRelationshipSuggestion",
  "properties": {
    "id": {
      "$ref": "../../type/basic.json#/definitions/uuid"
    },
    "operation": {
      "$ref": "../../type/ontologyChangeOperation.json"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    }
  },
  "required": ["id", "operation", "confidence", "rationale"],
  "additionalProperties": false
}
