{
  "$id": "https://open-metadata.org/schema/api/data/ontologyProfileReport.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OntologyProfileReport",
  "description": "OWL 2 DL profile validation result for an authored axiom.",
  "type": "object",
  "javaType": "org.openmetadata.schema.api.data.OntologyProfileReport",
  "properties": {
    "valid": {
      "type": "boolean"
    },
    "violations": {
      "type": "array",
      "items": {
        "$ref": "../../type/ontologyProfileViolation.json"
      },
      "default": []
    }
  },
  "required": ["valid", "violations"],
  "additionalProperties": false
}
