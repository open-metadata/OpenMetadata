{
  "$id": "https://open-metadata.org/schema/api/data/ontologyNaturalLanguageQueryRequest.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OntologyNaturalLanguageQueryRequest",
  "description": "Generate a visible, read-only SPARQL query for authorized ontology scopes.",
  "type": "object",
  "javaType": "org.openmetadata.schema.api.data.OntologyNaturalLanguageQueryRequest",
  "properties": {
    "glossaries": {
      "type": "array",
      "items": {
        "$ref": "../../type/basic.json#/definitions/fullyQualifiedEntityName"
      },
      "minItems": 1,
      "maxItems": 25,
      "uniqueItems": true
    },
    "question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    }
  },
  "required": ["glossaries", "question"],
  "additionalProperties": false
}
