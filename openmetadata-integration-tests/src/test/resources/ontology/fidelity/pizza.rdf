<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://www.co-ode.org/ontologies/pizza/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://www.co-ode.org/ontologies/pizza/">

    <owl:Ontology rdf:about="http://www.co-ode.org/ontologies/pizza/">
        <rdfs:label>Pizza Ontology</rdfs:label>
        <rdfs:comment>The classic OWL teaching ontology — pizza types, toppings, and bases. Adapted from the University of Manchester's Pizza tutorial.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://www.co-ode.org/ontologies/pizza/Pizza">
        <rdfs:label>Pizza</rdfs:label>
        <rdfs:comment>A pizza with a base and one or more toppings</rdfs:comment>
        <ont:icon>🍕</ont:icon>
        <ont:color>#E74C3C</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://www.co-ode.org/ontologies/pizza/PizzaBase">
        <rdfs:label>PizzaBase</rdfs:label>
        <rdfs:comment>The base of a pizza — thin crust, deep pan, or stuffed crust</rdfs:comment>
        <ont:icon>🫓</ont:icon>
        <ont:color>#F39C12</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://www.co-ode.org/ontologies/pizza/PizzaTopping">
        <rdfs:label>PizzaTopping</rdfs:label>
        <rdfs:comment>An ingredient placed on top of a pizza</rdfs:comment>
        <ont:icon>🧀</ont:icon>
        <ont:color>#27AE60</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://www.co-ode.org/ontologies/pizza/Country">
        <rdfs:label>Country</rdfs:label>
        <rdfs:comment>The country of origin for a named pizza style</rdfs:comment>
        <ont:icon>🌍</ont:icon>
        <ont:color>#3498DB</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://www.co-ode.org/ontologies/pizza/SpicinessLevel">
        <rdfs:label>SpicinessLevel</rdfs:label>
        <rdfs:comment>The spiciness classification of a topping (mild, medium, hot)</rdfs:comment>
        <ont:icon>🌶️</ont:icon>
        <ont:color>#E67E22</ont:color>
    </owl:Class>

    <!-- ===================== -->
    <!-- Properties            -->
    <!-- ===================== -->

    <!-- Pizza properties -->
    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/pizza/pizzaName">
        <rdfs:label>pizzaName</rdfs:label>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/pizza/calorieCount">
        <rdfs:label>calorieCount</rdfs:label>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <!-- PizzaBase properties -->
    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/pizza/baseType">
        <rdfs:label>baseType</rdfs:label>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/PizzaBase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/pizza/thickness">
        <rdfs:label>thickness</rdfs:label>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/PizzaBase"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- PizzaTopping properties -->
    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/pizza/toppingName">
        <rdfs:label>toppingName</rdfs:label>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/PizzaTopping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/pizza/isVegetarian">
        <rdfs:label>isVegetarian</rdfs:label>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/PizzaTopping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>

    <!-- Country properties -->
    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/pizza/countryName">
        <rdfs:label>countryName</rdfs:label>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/Country"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <!-- SpicinessLevel properties -->
    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/pizza/level">
        <rdfs:label>level</rdfs:label>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/SpicinessLevel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <!-- ===================== -->
    <!-- Relationships         -->
    <!-- ===================== -->

    <owl:ObjectProperty rdf:about="http://www.co-ode.org/ontologies/pizza/hasBase">
        <rdfs:label>hasBase</rdfs:label>
        <rdfs:comment>A pizza has exactly one base</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/pizza/PizzaBase"/>
        <ont:cardinality>many-to-one</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.co-ode.org/ontologies/pizza/hasTopping">
        <rdfs:label>hasTopping</rdfs:label>
        <rdfs:comment>A pizza has one or more toppings</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/pizza/PizzaTopping"/>
        <ont:cardinality>many-to-many</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.co-ode.org/ontologies/pizza/hasCountryOfOrigin">
        <rdfs:label>hasCountryOfOrigin</rdfs:label>
        <rdfs:comment>The country a named pizza originates from</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/pizza/Country"/>
        <ont:cardinality>many-to-one</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.co-ode.org/ontologies/pizza/hasSpiciness">
        <rdfs:label>hasSpiciness</rdfs:label>
        <rdfs:comment>The spiciness classification of a topping</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/pizza/PizzaTopping"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/pizza/SpicinessLevel"/>
        <ont:cardinality>many-to-one</ont:cardinality>
    </owl:ObjectProperty>

</rdf:RDF>
