<?xml version="1.0" encoding="UTF-8"?>
<!--
  Adapted from EDM Council FIBO — LOAN/LoansGeneral/Loans
  Source: https://github.com/edmcouncil/fibo
  Spec:   https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansGeneral/Loans/

  Copyright (c) 2016-2025 EDM Council, Inc.
  Copyright (c) 2016-2025 Object Management Group, Inc.
  Licensed under the MIT License — https://opensource.org/licenses/MIT

  This file is an adapted, simplified subset for educational use in
  Ontology Playground. It preserves the core semantics of FIBO loan
  concepts while reducing complexity for classroom instruction.
-->
<rdf:RDF
    xml:base="https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansGeneral/Loans/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansGeneral/Loans/">

  <owl:Ontology rdf:about="">
    <rdfs:label>FIBO Loans General (Adapted Subset)</rdfs:label>
    <rdfs:comment>Adapted from EDM Council FIBO Loans ontology for educational use in Ontology Playground. This is a subset model aligned with classes and semantics from LOAN/LoansGeneral/Loans. Source: https://github.com/edmcouncil/fibo — MIT License.</rdfs:comment>
  </owl:Ontology>

  <owl:Class rdf:about="Loan">
    <rdfs:label>Loan</rdfs:label>
    <rdfs:comment>Debt instrument whereby one party extends money or credit to another party with repayment obligations. Adapted from fibo-loan-ln-ln:Loan.</rdfs:comment>
    <ont:icon>📄</ont:icon>
    <ont:color>#00A9E0</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Borrower">
    <rdfs:label>Borrower</rdfs:label>
    <rdfs:comment>Party that signs loan obligations and is responsible for repayment. Adapted from fibo-loan-ln-ln:Borrower.</rdfs:comment>
    <ont:icon>👤</ont:icon>
    <ont:color>#0078D4</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Lender">
    <rdfs:label>Lender</rdfs:label>
    <rdfs:comment>Party that provides loan capital and sets contractual lending terms. Adapted from fibo-loan-ln-ln:Lender.</rdfs:comment>
    <ont:icon>🏦</ont:icon>
    <ont:color>#107C10</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Collateral">
    <rdfs:label>Collateral</rdfs:label>
    <rdfs:comment>Asset pledged to secure repayment obligations under a loan agreement. Adapted from fibo-fbc-dae-dbt:Collateral.</rdfs:comment>
    <ont:icon>🏠</ont:icon>
    <ont:color>#D83B01</ont:color>
  </owl:Class>

  <owl:Class rdf:about="LoanPaymentSchedule">
    <rdfs:label>LoanPaymentSchedule</rdfs:label>
    <rdfs:comment>Payment schedule associated with a loan-specific account. Adapted from fibo-loan-ln-ln:LoanPaymentSchedule.</rdfs:comment>
    <ont:icon>🗓️</ont:icon>
    <ont:color>#5C2D91</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Servicer">
    <rdfs:label>Servicer</rdfs:label>
    <rdfs:comment>Financial service provider that collects principal and interest on behalf of the lender. Adapted from fibo-loan-ln-ln:Servicer.</rdfs:comment>
    <ont:icon>🧾</ont:icon>
    <ont:color>#008272</ont:color>
  </owl:Class>

  <owl:Class rdf:about="PaymentHistory">
    <rdfs:label>PaymentHistory</rdfs:label>
    <rdfs:comment>Record of actual borrower payments toward principal, interest, and fees. Adapted from fibo-fbc-pas-caa:PaymentHistory.</rdfs:comment>
    <ont:icon>📚</ont:icon>
    <ont:color>#FFB900</ont:color>
  </owl:Class>

  <!-- Properties -->

  <owl:DatatypeProperty rdf:about="loanId">
    <rdfs:label>loanId</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="principalAmount">
    <rdfs:label>principalAmount</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="isInterestOnly">
    <rdfs:label>isInterestOnly</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <ont:propertyType>boolean</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="borrowerId">
    <rdfs:label>borrowerId</rdfs:label>
    <rdfs:domain rdf:resource="Borrower"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="creditScore">
    <rdfs:label>creditScore</rdfs:label>
    <rdfs:domain rdf:resource="Borrower"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <ont:propertyType>integer</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="lenderId">
    <rdfs:label>lenderId</rdfs:label>
    <rdfs:domain rdf:resource="Lender"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="lenderType">
    <rdfs:label>lenderType</rdfs:label>
    <rdfs:domain rdf:resource="Lender"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="assetType">
    <rdfs:label>assetType</rdfs:label>
    <rdfs:domain rdf:resource="Collateral"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="appraisedValue">
    <rdfs:label>appraisedValue</rdfs:label>
    <rdfs:domain rdf:resource="Collateral"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>USD</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="scheduleId">
    <rdfs:label>scheduleId</rdfs:label>
    <rdfs:domain rdf:resource="LoanPaymentSchedule"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="expectedPayments">
    <rdfs:label>expectedPayments</rdfs:label>
    <rdfs:domain rdf:resource="LoanPaymentSchedule"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <ont:propertyType>integer</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="servicerId">
    <rdfs:label>servicerId</rdfs:label>
    <rdfs:domain rdf:resource="Servicer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="paymentHistoryId">
    <rdfs:label>paymentHistoryId</rdfs:label>
    <rdfs:domain rdf:resource="PaymentHistory"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- Relationships -->

  <owl:ObjectProperty rdf:about="owedBy">
    <rdfs:label>owedBy</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="Borrower"/>
    <rdfs:comment>Relates a loan to the borrower obligated to repay it.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>Loan</ont:fromEntityId>
    <ont:toEntityId>Borrower</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="originatedBy">
    <rdfs:label>originatedBy</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="Lender"/>
    <rdfs:comment>Relates a loan to the lending organization that originated it.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>Loan</ont:fromEntityId>
    <ont:toEntityId>Lender</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="securedBy">
    <rdfs:label>securedBy</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="Collateral"/>
    <rdfs:comment>Relates a secured loan to pledged collateral assets.</rdfs:comment>
    <ont:cardinality>one-to-many</ont:cardinality>
    <ont:fromEntityId>Loan</ont:fromEntityId>
    <ont:toEntityId>Collateral</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="repaidBySchedule">
    <rdfs:label>repaidBySchedule</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="LoanPaymentSchedule"/>
    <rdfs:comment>Relates a loan to its payment schedule.</rdfs:comment>
    <ont:cardinality>one-to-one</ont:cardinality>
    <ont:fromEntityId>Loan</ont:fromEntityId>
    <ont:toEntityId>LoanPaymentSchedule</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="servicedBy">
    <rdfs:label>servicedBy</rdfs:label>
    <rdfs:domain rdf:resource="Loan"/>
    <rdfs:range rdf:resource="Servicer"/>
    <rdfs:comment>Relates a loan to the servicing organization collecting payments.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>Loan</ont:fromEntityId>
    <ont:toEntityId>Servicer</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="hasPaymentHistory">
    <rdfs:label>hasPaymentHistory</rdfs:label>
    <rdfs:domain rdf:resource="LoanPaymentSchedule"/>
    <rdfs:range rdf:resource="PaymentHistory"/>
    <rdfs:comment>Links a payment schedule to payment history records.</rdfs:comment>
    <ont:cardinality>one-to-one</ont:cardinality>
    <ont:fromEntityId>LoanPaymentSchedule</ont:fromEntityId>
    <ont:toEntityId>PaymentHistory</ont:toEntityId>
  </owl:ObjectProperty>

</rdf:RDF>
