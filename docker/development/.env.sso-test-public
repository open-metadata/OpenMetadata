# SSO Test Environment — PUBLIC client variant (issue #26591)
#
# Companion to .env.sso-test (which is the CONFIDENTIAL variant). This file
# configures the OM server as a PUBLIC custom-oidc client so that the browser
# drives the OIDC flow and the frontend /signup page runs getNameFromUserData
# (that helper is only invoked when clientType === public — see SignUpPage.tsx).
#
# It maps the username principal claim from `preferred_username`. The mock
# 'fallback-user' account deliberately omits preferred_username, so first-time
# login must self-signup via the UI's normalized-name fallback rather than
# leaving the required username field empty (the #26591 regression).
#
# Local run:
#   1. Start the mock OIDC provider:
#      cd docker/development
#      docker compose --profile sso-test up -d mock-oidc-provider
#   2. Start OM with this env file:
#      docker compose --env-file .env.sso-test-public up -d
#   3. Run the public-client SSO tests:
#      cd openmetadata-ui/src/main/resources/ui
#      npx playwright test --config=playwright.sso.public.config.ts
#
# NOTE: server-side URLs use the Docker hostname (mock-oidc-provider:9090);
# browser-facing URLs use localhost:9090.

# Authentication provider — custom-oidc uses OidcAuthenticator in the browser
AUTHENTICATION_PROVIDER=custom-oidc
CUSTOM_OIDC_AUTHENTICATION_PROVIDER_NAME=mock-oidc
# PUBLIC client → browser-driven flow → frontend getNameFromUserData runs
AUTHENTICATION_CLIENT_TYPE=public
AUTHENTICATION_RESPONSE_TYPE=code
AUTHENTICATION_PUBLIC_KEYS=[http://mock-oidc-provider:9090/jwks,http://localhost:8585/api/v1/system/config/jwks]
AUTHENTICATION_AUTHORITY=http://localhost:9090
# The mock provider's public client (token_endpoint_auth_method: none)
AUTHENTICATION_CLIENT_ID=openmetadata-test-public
AUTHENTICATION_CALLBACK_URL=http://localhost:8585/callback
AUTHENTICATION_ENABLE_SELF_SIGNUP=true
# Username from `preferred_username`, email from `email` (the #26591 mapping).
AUTHENTICATION_JWT_PRINCIPAL_CLAIMS_MAPPING=[username:preferred_username,email:email]
AUTHENTICATION_SESSION_EXPIRY=604800
AUTHENTICATION_MAX_ACTIVE_SESSIONS_PER_USER=5
